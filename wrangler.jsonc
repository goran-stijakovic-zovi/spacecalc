{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spacecalc",
  "main": "./worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    { "pattern": "spacecalc.zoviconsulting.com/*", "zone_name": "zoviconsulting.com" }
  ]
}
